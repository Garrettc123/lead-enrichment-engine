# Server
PORT=3000
NODE_ENV=production
APP_URL=http://localhost:3000
ADMIN_API_KEY=your-admin-key-here

# Database (optional - in-memory fallback if not set)
MONGODB_URI=mongodb://localhost:27017/lead_enrichment

# Redis (optional - synchronous batch fallback if not set)
REDIS_URL=redis://localhost:6379

# Stripe Billing
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_SCALE=price_...

# Data Source API Keys
CLEARBIT_API_KEY=sk_...
HUNTER_API_KEY=...
APOLLO_API_KEY=...
CRUNCHBASE_API_KEY=...
GITHUB_TOKEN=ghp_...
TWITTER_BEARER_TOKEN=...
NEWS_API_KEY=...
BUILTWITH_API_KEY=...

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
ALLOWED_ORIGINS=*
